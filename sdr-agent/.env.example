# ── LLM ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith observability ───────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=prosp-sdr

# ── Lead data ─────────────────────────────────────────────────────
APOLLO_API_KEY=...
CLEARBIT_API_KEY=...
TAVILY_API_KEY=...

# ── Outreach execution ────────────────────────────────────────────
INSTANTLY_API_KEY=...
INSTANTLY_CAMPAIGN_ID=...
UNIPILE_API_KEY=...
UNIPILE_ACCOUNT_ID=...

# ── CRM ───────────────────────────────────────────────────────────
HUBSPOT_API_KEY=...

# ── Infrastructure ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://sdr:sdrpass@localhost:5432/sdrdb

# ── Auth ──────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string-in-production

# ── Agent behaviour ───────────────────────────────────────────────
AUTO_APPROVE_THRESHOLD=0.85
QUALIFY_THRESHOLD=0.6
MAX_TOUCHES=8

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
APP_ENV=development
